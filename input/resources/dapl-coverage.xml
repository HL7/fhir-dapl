<?xml version="1.0" encoding="UTF-8"?>
<StructureDefinition
    xmlns="http://hl7.org/fhir">
    <id value="dapl-coverage"/>
    <meta>
        <versionId value="1"/>
        <lastUpdated value="2026-03-27T02:03:11.293+00:00"/>
    </meta>
    <url value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-coverage"/>
    <version value="1.0.0-ballot"/>
    <name value="DAPLCoverage"/>
    <title value="DAPL Coverage"/>
    <status value="active"/>
    <experimental value="false"/>
    <publisher value="HL7 Cross-Group Projects"/>
    <description value="The profile establishes the core elements, extensions, vocabularies and value sets for representing deidentified or anonymized Coverage."/>
    <jurisdiction>
        <coding>
            <system value="urn:iso:std:iso:3166"/>
            <code value="US"/>
            <display value="United States of America"/>
        </coding>
        <text value="United States of America"/>
    </jurisdiction>
    <fhirVersion value="4.0.1"/>
    <kind value="resource"/>
    <abstract value="false"/>
    <type value="Coverage"/>
    <baseDefinition value="http://hl7.org/fhir/StructureDefinition/Coverage"/>
    <derivation value="constraint"/>
    <differential>
        <element id="Coverage">
            <path value="Coverage"/>
            <short value="DAPL Coverage"/>
            <definition value="The profile establishes the core elements, extensions, vocabularies and value sets for representing deidentified or anonymized Coverage."/>
        </element>
        <element id="Coverage.id">
            <path value="Coverage.id"/>
            <short value="The Coverage identifier generated by the DARTS deidentification or anonymization service"/>
            <definition value="DAPL Coverage identifier."/>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.text">
            <path value="Coverage.text"/>
            <short value="Cannot include any text in the resource as part of the deidentified or anonymized data."/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Coverage.contained">
            <path value="Coverage.contained"/>
            <short value="Cannot include any contained resources in the resource as part of the deidentified or anonymized data."/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Coverage.status">
            <path value="Coverage.status"/>
            <type>
                <code value="code"/>
            </type>
            <fixedCode value="active"/>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.type">
            <path value="Coverage.type"/>
            <min value="1"/>
            <max value="1"/>
            <type>
                <code value="CodeableConcept"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.policyHolder.display">
	      <path value="Coverage.policyHolder.display"/>
	      <min value="0"/>
	      <max value="0"/>
	      <mustSupport value="false"/>
	    </element>
        <element id="Coverage.beneficiary">
            <path value="Coverage.beneficiary"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-patient"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.beneficiary.display">
            <path value="Coverage.beneficiary.display"/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Coverage.period">
            <path value="Coverage.period"/>
		      <constraint>
		        <key value="dapl-cov-1"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and Period.start.exists() implies $this.start.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="dapl-cov-1a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.start.exists() implies $this.start.toString() &gt;= '1900'"/>
		      </constraint>
		      <constraint>
		        <key value="dapl-cov-2"/>
		        <severity value="error"/>
		        <human
		               value="All Period.emd data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and Period.end.exists() implies $this.end.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="dapl-cov-2a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.end data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.end.exists() implies $this.end.toString() &gt;= '1900'"/>
		      </constraint>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.payor">
            <path value="Coverage.payor"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-patient"/>
                <targetProfile value="http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-relatedperson"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Coverage.payor.display">
            <path value="Coverage.payor.display"/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
         <element id="Coverage.costToBeneficiary">
	      <path value="Coverage.costToBeneficiary"/>
	      <min value="0"/>
	      <max value="0"/>
	      <mustSupport value="false"/>
	    </element>
    </differential>
</StructureDefinition>