<?xml version="1.0" encoding="UTF-8"?>
<StructureDefinition
    xmlns="http://hl7.org/fhir">
    <id value="dapl-deidentified-encounter"/>
    <meta>
        <versionId value="1"/>
        <lastUpdated value="2026-03-27T02:03:11.293+00:00"/>
    </meta>
    <url value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-encounter"/>
    <version value="1.0.0-ballot"/>
    <name value="DAPLEncounter"/>
    <title value="DAPL De-identified Encounter"/>
    <status value="active"/>
    <experimental value="false"/>
    <publisher value="HL7 Cross-Group Projects"/>
    <description value="The profile establishes the core elements, extensions, vocabularies and value sets for representing deidentified encounters or visit information."/>
    <jurisdiction>
        <coding>
            <system value="urn:iso:std:iso:3166"/>
            <code value="US"/>
            <display value="United States of America"/>
        </coding>
        <text value="United States of America"/>
    </jurisdiction>
    <fhirVersion value="4.0.1"/>
    <kind value="resource"/>
    <abstract value="false"/>
    <type value="Encounter"/>
    <baseDefinition value="http://hl7.org/fhir/StructureDefinition/Encounter"/>
    <derivation value="constraint"/>
    <differential>
        <element id="Encounter">
            <path value="Encounter"/>
            <short value="DAPL Deidentified Encounter"/>
            <definition value="The profile establishes the core elements, extensions, vocabularies and value sets for representing deidentified encounters or visit information."/>
        </element>
        <element id="Encounter.id">
            <path value="Encounter.id"/>
            <short value="The Encounter identifier generated by DARTS deidentification service"/>
            <definition value="DAPL Resource identifier."/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.text">
            <path value="Encounter.text"/>
            <short value="Cannot include any text in the resource as part of the deidentified data."/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Encounter.contained">
            <path value="Encounter.contained"/>
            <short value="Cannot include any contained resources in the resource as part of the deidentified data."/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Encounter.extension:age">
            <path value="Encounter.extension"/>
            <short value="Age of the Patient computed using birthDate and the visit dates of the encounter"/>
            <sliceName value="dapl-age-extension"/>
            <min value="1"/>
            <max value="1"/>
            <type>
                <code value="Extension"/>
                <profile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-age-extension"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.status">
            <path value="Encounter.status"/>
            <min value="1"/>
            <max value="1"/>
            <mustSupport value="true"/>  
        </element>
         <element id="Encounter.class">
            <path value="Encounter.class"/>
            <min value="1"/>
            <max value="1"/>
            <mustSupport value="true"/>  
        </element>
        <element id="Encounter.type">
            <path value="Encounter.type"/>
            <min value="1"/>
            <max value="*"/>
            <mustSupport value="true"/>  
            <binding>
                <strength value="extensible"/>
                <description value="The set of codes indicating the type of encounter"/>
                <valueSet value="http://cts.nlm.nih.gov/fhir/ValueSet/2.16.840.1.113762.1.4.1267.23"/>
            </binding>
        </element>
        <element id="Encounter.subject">
            <path value="Encounter.subject"/>
            <min value="1"/>
            <max value="1"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-patient"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.subject.display">
            <path value="Encounter.subject.display"/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Encounter.participant">
            <path value="Encounter.participant"/>
            <min value="0"/>
            <max value="1"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.participant.type">
            <path value="Encounter.participant.type"/>
            <min value="0"/>
            <max value="*"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.participant.period">
            <path value="Encounter.participant.period"/>
            <min value="0"/>
            <max value="1"/>
		      <constraint>
		        <key value="dapl-enc-1"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and $this.start.exists() implies $this.start.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="dapl-enc-1a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.start.exists() implies $this.start.toString() &gt;= '1900'"/>
		      </constraint>
		    
		      <constraint>
		        <key value="dapl-enc-2"/>
		        <severity value="error"/>
		        <human
		               value="All Period.emd data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and $this.end.exists() implies $this.end.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="uds-plus-enc-2a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.end data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.end.exists() implies $this.end.toString() &gt;= '1900'"/>
		      </constraint>
		      
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.participant.individual">
            <path value="Encounter.participant.individual"/>
            <min value="0"/>
            <max value="1"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/core/StructureDefinition/us-core-practitioner"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.period">
            <path value="Encounter.period"/>
            <min value="0"/>
            <max value="1"/>
            <constraint>
		        <key value="dapl-enc-3"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and $this.start.exists() implies $this.start.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="dapl-enc-3a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.start data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.start.exists() implies $this.start.toString() &gt;= '1900'"/>
		      </constraint>
		    
		      <constraint>
		        <key value="dapl-enc-4"/>
		        <severity value="error"/>
		        <human
		               value="All Period.emd data elements should be truncated to a year only for de-identified resources."/>
		        <expression
		                    value="$this is Period and $this.end.exists() implies $this.end.toString().length() = 4"/>
		      </constraint>
		      <constraint>
		        <key value="uds-plus-enc-4a"/>
		        <severity value="error"/>
		        <human
		               value="All Period.end data elements should have valid year &gt; 1900"/>
		        <expression
		                    value="$this is Period and Period.end.exists() implies $this.end.toString() &gt;= '1900'"/>
		      </constraint>
		      
            <mustSupport value="true"/> 
        </element>
        <element id="Encounter.reasonCode">
            <path value="Encounter.reasonCode"/>
            <min value="0"/>
            <max value="*"/>
            <mustSupport value="true"/>
        </element>
        
        <element id="Encounter.reasonReference">
            <path value="Encounter.reasonReference"/>
            <min value="0"/>
            <max value="*"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-diagnosis"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.reasonReference.display">
            <path value="Encounter.reasonReference.display"/>
            <min value="0"/>
            <max value="0"/>
            <mustSupport value="false"/>
        </element>
        <element id="Encounter.diagnosis">
            <path value="Encounter.diagnosis"/>
            <min value="0"/>
            <max value="*"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.diagnosis.condition">
            <path value="Encounter.diagnosis.condition"/>
            <min value="1"/>
            <max value="1"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-diagnosis"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.diagnosis.use">
            <path value="Encounter.diagnosis.use"/>
            <min value="0"/>
            <max value="1"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.diagnosis.rank">
            <path value="Encounter.diagnosis.rank"/>
            <min value="0"/>
            <max value="1"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.hospitalization">
            <path value="Encounter.hospitalization"/>
            <min value="0"/>
            <max value="1"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.hospitalization.dischargeDisposition">
            <path value="Encounter.hospitalization.dischargeDisposition"/>
            <min value="0"/>
            <max value="1"/>
            <mustSupport value="true"/>
            <binding>
                <strength value="preferred"/>
                <description value="The set of codes indicating the discharge disposition"/>
                <valueSet value="http://terminology.hl7.org/ValueSet/v3-USEncounterDischargeDisposition|5.0.0"/>
            </binding>
        </element>
        
        <element id="Encounter.location">
            <path value="Encounter.location"/>
            <min value="0"/>
            <max value="*"/>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.location.location">
            <path value="Encounter.location.location"/>
            <min value="1"/>
            <max value="1"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/dapl/StructureDefinition/dapl-deidentified-location"/>
            </type>
            <mustSupport value="true"/>
        </element>
        <element id="Encounter.serviceProvider">
            <path value="Encounter.serviceProvider"/>
            <min value="0"/>
            <max value="1"/>
            <type>
                <code value="Reference"/>
                <targetProfile value="http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization"/>
            </type>
            <mustSupport value="true"/>
        </element>
    </differential>
</StructureDefinition>